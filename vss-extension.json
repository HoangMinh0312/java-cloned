{
  "manifestVersion": 1,
  "id": "simple-decorator",
  "version": "1.0.0",
  "name": "Simple Decorator",
  "publisher": "my-publisher",
  "targets": [{ "id": "Microsoft.VisualStudio.Services" }],
  "contributions": [
    {
      "id": "my-decorator",
